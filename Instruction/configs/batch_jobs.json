      "class": "IDRIDDesc",
      "kwargs": {}
    },
    "save_path": "batchs/instructions/loacal/IDRID_seg.jsonl",
    "image_path": "/path/to/Results_IDRID_seg/M0/images",
    "prefix_name": "IDRID_seg/"
  },
  "MICCAI": {
    "action": "create_batch",
    "prompt": "miccai_lt_batch_prompt",
    "image_list": {
      "type": "dir",
      "path": "/path/to/Results_MICCAI_task2/M0/images"
    },
    "desc": {
      "module": "Desc.MICCAIDesc",
      "class": "MICCAIDesc",
      "kwargs": {}
