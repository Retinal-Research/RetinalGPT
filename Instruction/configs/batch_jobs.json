  "ODIR": {
    "action": "create_batch",
    "prompt": "odir_batch_prompt",
    "image_list": {
      "type": "csv_column",
      "path": "Results_APTOS/M4/disc_features.csv",
      "column": 0
    },
    "desc": {
      "module": "Desc.alignment_description",
      "class": "AlignDesc",
      "kwargs": {
        "fractal_analysis_csv": "Results_APTOS/M4/disc_features.csv",
