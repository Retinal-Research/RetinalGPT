{
  "APTOS": {
    "action": "create_batch",
    "prompt": "aptos_batch_prompt",
    "image_list": {
      "type": "csv_filter_suffix",
      "path": "APTOS/train.csv",
      "match_column": 1,
      "match_value": 0,
      "output_column": 0,
      "suffix": ".png"
    },
    "desc": {
      "module": "Desc.alignment_description",
      "class": "AlignDesc",
      "kwargs": {
        "fractal_analysis_csv": "Results_APTOS/M4/macula_features.csv",
        "quality_csv": "Results_APTOS/M1/results_ensemble.csv",
        "dr_label_csv": "APTOS/train.csv"
      }
    },
    "save_path": "/path/to/batchs/inputs/APTOS_0.jsonl",
    "img_path": "APTOS/train/"
  },
  "APTOS_unpack": {
    "action": "unpack_outputs",
    "batch_path": "/path/to/batchs/outputs/APTOS/batch_output.jsonl",
    "save_path": "/path/to/batchs/json_list/APTOS.jsonl",
    "instruction_save": "/path/to/batchs/instructions/instruction_APTOS.json",
    "prefix_name": "APTOS",
    "align": true
  },
  "EyeQ": {
    "action": "generate_conversations",
    "prompt": "eyeq_batch_prompt",
    "image_list": {
      "type": "explicit",
      "values": [
        "12802_right.png",
        "12829_left.png",
        "12829_right.png",
        "12837_right.png",
        "12839_left.png",
        "12856_right.png",
        "12864_left.png",
        "12877_left.png",
        "25829_right.png",
        "2582_left.png",
        "25875_left.png",
        "25893_right.png",
        "26006_left.png",
        "26007_right.png",
        "28296_right.png",
        "28307_left.png",
        "28328_left.png",
        "28333_left.png"
      ]
    },
    "desc": {
      "module": "Desc.EyeQDesc",
      "class": "EyeQDesc",
      "kwargs": {
        "dr_label_csv": "/path/to/EyePACS/Label_EyeQ_good.csv"
      }
    },
    "save_path": "batchs/instructions/loacal/test.jsonl",
    "image_path": "/path/to/EyePACS/good_quality/image_224",
    "prefix_name": "EyePACS/"
  },
  "IDRID": {
